@model SistemaStock.Models.Producto

@{
    ViewData["Title"] = "Detalle del Producto";
    var stock = Model.Stock ?? 0;
    var minimo = Model.StockMinimo ?? 0;
    var stockClass = stock == 0 ? "out" : (stock <= minimo ? "low" : "ok");
}

<div class="page-header">
    <div class="page-header-text">
        <nav class="breadcrumb-nav">
            <a asp-action="Index">Productos</a>
            <i class="bi bi-chevron-right"></i>
            <span>Detalle</span>
        </nav>
        <h1>@Model.Nombre</h1>
        <p>Código: @Model.Codigo</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Movimiento" asp-route-id="@Model.ProductoId" asp-route-tipo="Entrada" class="btn btn-success">
            <i class="bi bi-arrow-down-circle"></i> Entrada
        </a>
        <a asp-action="Movimiento" asp-route-id="@Model.ProductoId" asp-route-tipo="Salida" class="btn btn-danger">
            <i class="bi bi-arrow-up-circle"></i> Salida
        </a>
        <a asp-action="Edit" asp-route-id="@Model.ProductoId" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Mensaje"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
    </div>
}

<div class="content-card mb-4">
    <div class="content-card-body padded">
        <dl class="detail-grid">
            <div class="detail-item">
                <dt>Código</dt>
                <dd>@Model.Codigo</dd>
            </div>
            <div class="detail-item">
                <dt>Nombre</dt>
                <dd>@Model.Nombre</dd>
            </div>
            <div class="detail-item">
                <dt>Categoría</dt>
                <dd><span class="badge-category">@(Model.Categoria?.Nombre ?? "—")</span></dd>
            </div>
            <div class="detail-item">
                <dt>Precio</dt>
                <dd class="price-tag">@Model.Precio.ToString("C")</dd>
            </div>
            <div class="detail-item">
                <dt>Stock actual</dt>
                <dd>
                    <span class="badge-stock @stockClass">@stock unidades</span>
                </dd>
            </div>
            <div class="detail-item">
                <dt>Stock mínimo</dt>
                <dd>@minimo unidades</dd>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
            {
                <div class="detail-item" style="grid-column: 1 / -1;">
                    <dt>Descripción</dt>
                    <dd>@Model.Descripcion</dd>
                </div>
            }
        </dl>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h2><i class="bi bi-clock-history me-2"></i>Historial de movimientos</h2>
    </div>

    @if (!Model.Movimientos.Any())
    {
        <div class="empty-state">
            <i class="bi bi-arrow-left-right"></i>
            <h3>Sin movimientos registrados</h3>
            <p>Registra una entrada o salida para comenzar el historial.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-modern">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Motivo</th>
                        <th>Usuario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mov in Model.Movimientos)
                    {
                        var esEntrada = mov.Tipo == SistemaStock.Models.MovimientoStock.Tipos.Entrada;
                        <tr>
                            <td>@mov.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="badge-movement @(esEntrada ? "entrada" : "salida")">
                                    <i class="bi @(esEntrada ? "bi-arrow-down-circle" : "bi-arrow-up-circle")"></i>
                                    @mov.Tipo
                                </span>
                            </td>
                            <td><strong>@(esEntrada ? "+" : "-")@mov.Cantidad</strong></td>
                            <td>@(string.IsNullOrWhiteSpace(mov.Motivo) ? "—" : mov.Motivo)</td>
                            <td>@(mov.Usuario ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
