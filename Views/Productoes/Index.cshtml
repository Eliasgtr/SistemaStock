@model IEnumerable<SistemaStock.Models.Producto>

@{
    ViewData["Title"] = "Productos";
    var total = Model.Count();
    var stockBajo = Model.Count(p => p.Stock.HasValue && p.StockMinimo.HasValue && p.Stock <= p.StockMinimo && p.Stock > 0);
    var sinStock = Model.Count(p => !p.Stock.HasValue || p.Stock == 0);
}

<div class="page-header">
    <div class="page-header-text">
        <h1>Productos</h1>
        <p>Gestiona el inventario de tu negocio</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nuevo producto
    </a>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon primary"><i class="bi bi-box-seam"></i></div>
        <div>
            <div class="stat-value">@total</div>
            <div class="stat-label">Total productos</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon warning"><i class="bi bi-exclamation-triangle"></i></div>
        <div>
            <div class="stat-value">@stockBajo</div>
            <div class="stat-label">Stock bajo</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon danger"><i class="bi bi-x-circle"></i></div>
        <div>
            <div class="stat-value">@sinStock</div>
            <div class="stat-label">Sin stock</div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h2><i class="bi bi-list-ul me-2"></i>Listado de productos</h2>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="tableSearch" placeholder="Buscar producto..." />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h3>No hay productos registrados</h3>
            <p>Comienza agregando tu primer producto al inventario.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Crear producto
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-modern" data-searchable>
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>Stock</th>
                        <th>Mínimo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var stock = item.Stock ?? 0;
                        var minimo = item.StockMinimo ?? 0;
                        var stockClass = stock == 0 ? "out" : (stock <= minimo ? "low" : "ok");
                        var stockIcon = stock == 0 ? "bi-x-circle" : (stock <= minimo ? "bi-exclamation-circle" : "bi-check-circle");

                        <tr data-searchable-row>
                            <td>
                                <div class="table-product-name">@item.Nombre</div>
                                <div class="table-product-code">@item.Codigo</div>
                                @if (!string.IsNullOrWhiteSpace(item.Descripcion))
                                {
                                    <div class="text-muted" style="font-size:0.8rem; margin-top:2px;">@item.Descripcion</div>
                                }
                            </td>
                            <td>
                                <span class="badge-category">@(item.Categoria?.Nombre ?? "—")</span>
                            </td>
                            <td>
                                <span class="price-tag">@item.Precio.ToString("C")</span>
                            </td>
                            <td>
                                <span class="badge-stock @stockClass">
                                    <i class="bi @stockIcon"></i> @stock
                                </span>
                            </td>
                            <td>@minimo</td>
                            <td>
                                <div class="actions-cell">
                                    <a asp-action="Movimiento" asp-route-id="@item.ProductoId" asp-route-tipo="Entrada"
                                       class="btn-action" title="Movimiento de stock" style="color:var(--success);">
                                        <i class="bi bi-arrow-left-right"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.ProductoId"
                                       class="btn-action action-view" title="Ver detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.ProductoId"
                                       class="btn-action action-edit" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.ProductoId"
                                       class="btn-action action-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
