@model IEnumerable<SistemaStock.Models.Categoria>

@{
    ViewData["Title"] = "Categorías";
    var total = Model.Count();
}

<div class="page-header">
    <div class="page-header-text">
        <h1>Categorías</h1>
        <p>Organiza tus productos por categorías</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nueva categoría
    </a>
</div>

<div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); max-width: 320px;">
    <div class="stat-card">
        <div class="stat-icon primary"><i class="bi bi-tags"></i></div>
        <div>
            <div class="stat-value">@total</div>
            <div class="stat-label">Total categorías</div>
        </div>
    </div>
</div>

<div class="content-card">
    <div class="content-card-header">
        <h2><i class="bi bi-list-ul me-2"></i>Listado de categorías</h2>
        <div class="search-box">
            <i class="bi bi-search"></i>
            <input type="text" id="tableSearch" placeholder="Buscar categoría..." />
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="bi bi-tags"></i>
            <h3>No hay categorías registradas</h3>
            <p>Crea categorías para organizar mejor tus productos.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg"></i> Crear categoría
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table-modern" data-searchable>
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr data-searchable-row>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="stat-icon primary" style="width:36px;height:36px;font-size:0.9rem;border-radius:8px;">
                                        <i class="bi bi-tag"></i>
                                    </div>
                                    <span class="table-product-name">@item.Nombre</span>
                                </div>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <a asp-action="Details" asp-route-id="@item.CategoriaId"
                                       class="btn-action action-view" title="Ver detalles">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.CategoriaId"
                                       class="btn-action action-edit" title="Editar">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.CategoriaId"
                                       class="btn-action action-delete" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
