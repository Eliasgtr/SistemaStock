@model SistemaStock.Application.ViewModels.MovimientoStockViewModel

@{
    var esEntrada = Model.Tipo == SistemaStock.Domain.Entities.MovimientoStock.Tipos.Entrada;
    ViewData["Title"] = esEntrada ? "Entrada de Stock" : "Salida de Stock";
}

<div class="page-header">
    <div class="page-header-text">
        <nav class="breadcrumb-nav">
            <a asp-action="Index">Productos</a>
            <i class="bi bi-chevron-right"></i>
            <a asp-action="Details" asp-route-id="@Model.ProductoId">@Model.ProductoNombre</a>
            <i class="bi bi-chevron-right"></i>
            <span>@(esEntrada ? "Entrada" : "Salida")</span>
        </nav>
        <h1>@(esEntrada ? "Entrada de stock" : "Salida de stock")</h1>
        <p>@Model.ProductoNombre — Código: @Model.ProductoCodigo</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="content-card">
            <div class="content-card-body padded">
                <div class="detail-item mb-0">
                    <dt>Stock actual</dt>
                    <dd>
                        <span class="badge-stock @(Model.StockActual == 0 ? "out" : "ok")" style="font-size:1rem;">
                            @Model.StockActual unidades
                        </span>
                    </dd>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="form-card wide mb-0">
            <form asp-action="Movimiento" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                <input type="hidden" asp-for="ProductoId" />
                <input type="hidden" asp-for="ProductoNombre" />
                <input type="hidden" asp-for="ProductoCodigo" />
                <input type="hidden" asp-for="StockActual" />

                <div class="mb-3">
                    <label asp-for="Tipo" class="form-label"></label>
                    <div class="d-flex gap-2">
                        <label class="movement-type-option @(esEntrada ? "active entrada" : "")">
                            <input type="radio" asp-for="Tipo" value="Entrada" class="d-none" />
                            <i class="bi bi-arrow-down-circle"></i> Entrada
                        </label>
                        <label class="movement-type-option @(!esEntrada ? "active salida" : "")">
                            <input type="radio" asp-for="Tipo" value="Salida" class="d-none" />
                            <i class="bi bi-arrow-up-circle"></i> Salida
                        </label>
                    </div>
                    <span asp-validation-for="Tipo" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Cantidad" class="form-label"></label>
                    <div class="input-icon-group">
                        <i class="bi bi-123 input-icon"></i>
                        <input asp-for="Cantidad" class="form-control" type="number" min="1" placeholder="Cantidad de unidades" />
                    </div>
                    <span asp-validation-for="Cantidad" class="text-danger small"></span>
                    @if (!esEntrada)
                    {
                        <div class="form-hint">Máximo disponible: @Model.StockActual unidades.</div>
                    }
                </div>

                <div class="mb-3">
                    <label asp-for="Motivo" class="form-label"></label>
                    <textarea asp-for="Motivo" class="form-control" rows="3"
                              placeholder="@(esEntrada ? "Ej: Compra a proveedor, devolución de cliente..." : "Ej: Venta, producto dañado, merma...")"></textarea>
                    <span asp-validation-for="Motivo" class="text-danger small"></span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn @(esEntrada ? "btn-success" : "btn-danger")">
                        <i class="bi @(esEntrada ? "bi-arrow-down-circle" : "bi-arrow-up-circle")"></i>
                        Registrar @(esEntrada ? "entrada" : "salida")
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.ProductoId" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.querySelectorAll('.movement-type-option input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function () {
                const tipo = this.value;
                const url = new URL(window.location.href);
                url.searchParams.set('tipo', tipo);
                window.location.href = url.toString();
            });
        });
    </script>
}
