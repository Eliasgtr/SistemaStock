@inject SistemaStock.Infrastructure.Persistence.SistemaStockContext DbContext
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var userName = Context.Session.GetString("Nombre") ?? "Usuario";
    var userInitial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";

    var userIdStr = Context.Session.GetString("UsuarioId");
    int countLowStock = 0;
    if (int.TryParse(userIdStr, out int userId))
    {
        countLowStock = DbContext.Productos
            .Count(p => p.UsuarioId == userId && (p.Stock == 0 || p.Stock <= p.StockMinimo));
    }
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Stock</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SistemaStock.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <div class="app-layout">
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <aside class="sidebar" id="sidebar">
            <a class="sidebar-brand" asp-controller="Productoes" asp-action="Index">
                <i class="bi bi-box-seam-fill"></i>
                <span>Sistema de Stock</span>
            </a>

            <nav class="sidebar-nav">
                <a class="sidebar-link @(controller == "Productoes" && action != "Notificaciones" ? "active" : "")"
                   asp-controller="Productoes" asp-action="Index">
                    <i class="bi bi-box-seam"></i>
                    <span>Productos</span>
                </a>
                <a class="sidebar-link @(controller == "Categorias" ? "active" : "")"
                   asp-controller="Categorias" asp-action="Index">
                    <i class="bi bi-tags"></i>
                    <span>Categorías</span>
                </a>
                <a class="sidebar-link @(controller == "Productoes" && action == "Notificaciones" ? "active" : "")"
                   asp-controller="Productoes" asp-action="Notificaciones">
                    <i class="bi bi-bell"></i>
                    <span>Notificaciones</span>
                    @if (countLowStock > 0)
                    {
                        <span class="badge bg-danger rounded-pill ms-auto" style="font-size: 0.75rem; padding: 0.25em 0.6em;">@countLowStock</span>
                    }
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="user-card">
                    <div class="user-avatar">@userInitial</div>
                    <div class="user-info">
                        <div class="user-name">@userName</div>
                        <div class="user-role">Administrador</div>
                    </div>
                </div>
                <a class="btn-logout" asp-controller="Cuenta" asp-action="Logout">
                    <i class="bi bi-box-arrow-right"></i>
                    Cerrar sesión
                </a>
            </div>
        </aside>

        <div class="main-wrapper">
            <header class="topbar">
                <button class="sidebar-toggle" id="sidebarToggle" type="button" aria-label="Abrir menú">
                    <i class="bi bi-list fs-5"></i>
                </button>
                <span class="topbar-title">@ViewData["Title"]</span>
            </header>

            <main class="app-main" role="main">
                @RenderBody()
            </main>

            <footer class="app-footer">
                <i class="bi bi-c-circle"></i> @DateTime.Now.Year — Sistema de Gestión de Inventario
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
