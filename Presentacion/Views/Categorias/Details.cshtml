@model SistemaStock.Domain.Entities.Categoria

@{
    ViewData["Title"] = "Detalle de Categoría";
}

<div class="page-header">
    <div class="page-header-text">
        <nav class="breadcrumb-nav">
            <a asp-action="Index">Categorías</a>
            <i class="bi bi-chevron-right"></i>
            <span>Detalle</span>
        </nav>
        <h1>@Model.Nombre</h1>
        <p>Información de la categoría</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.CategoriaId" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Editar
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</div>

<div class="content-card">
    <div class="content-card-body padded">
        <dl class="detail-grid">
            <div class="detail-item">
                <dt>ID</dt>
                <dd>#@Model.CategoriaId</dd>
            </div>
            <div class="detail-item">
                <dt>Nombre</dt>
                <dd><span class="badge-category">@Model.Nombre</span></dd>
            </div>
        </dl>
    </div>
</div>
